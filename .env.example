# Postgres direct connection (Drizzle migrations + queries)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_PASSWORD=<your-supabase-db-password>

# Supabase — server-side
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Supabase — also used server-side; safe to mirror to client
SUPABASE_ANON_KEY=sb_publishable_...

# Supabase — client (Expo bundles into the app)
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Server URL the mobile app calls (set after Render deploy in slice 0b)
# EXPO_PUBLIC_API_URL=https://...

# Inference providers
GEMINI_API_KEY=

# Analytics (slice 9)
# SENTRY_DSN_SERVER=
# SENTRY_DSN_MOBILE=
# POSTHOG_API_KEY=
