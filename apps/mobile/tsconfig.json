{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "rxdb-supabase": ["../../node_modules/rxdb-supabase/build/src/supabase-replication"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "./nativewind-env.d.ts",
    "types/**/*.d.ts"
  ]
}